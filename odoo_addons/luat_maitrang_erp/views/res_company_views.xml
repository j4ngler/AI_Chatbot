<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_form_inherit_luat_maitrang" model="ir.ui.view">
        <field name="name">res.company.form.inherit.luat_maitrang</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Luật / Chatbot" name="legal_chatbot">
                    <group>
                        <field name="legal_chatbot_api_url" placeholder="http://127.0.0.1:8000" widget="url"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
