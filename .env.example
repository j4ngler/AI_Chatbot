# Sao chép thành .env và điền giá trị. Docker Compose đọc env_file nếu có file .env.

# LLM: hiện chỉ dùng Ollama. (OpenAI / Gemini — tạm gỡ khỏi code; bật lại sau nếu cần.)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
# Giảm drift sang tiếng Trung với Qwen: 0.05–0.15 (mặc định 0.15)
OLLAMA_TEMPERATURE=0.15

# RAG (tùy chọn)
RAG_MODE=
HYBRID_ALPHA=0.5
RETRIEVE_K=20
TOP_K_DEFAULT=3
MIN_RETRIEVAL_SCORE=
DENSE_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
VECTOR_STORE_DIR=data/vector_db/file_based_demo

ROUTER_ENABLED=true
REFLECTION_ENABLED=
# Tăng tốc nhưng giữ độ chính xác: adaptive retrieval + nén context theo từ khóa + cache trả lời
FAST_ACCURATE_MODE=true
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_TTL_SECONDS=300
ANSWER_CACHE_MAX_ITEMS=300

# Demo web: CORS, danh sách origin cách nhau bởi dấu phẩy (mặc định *)
CORS_ALLOW_ORIGINS=*

# CoSIng (EU) — tab tra cứu hóa chất trên demo; cần Chrome/Edge + Selenium
COSING_ENABLED=false
COSING_CACHE_DIR=data/cache/cosing
COSING_BROWSER=chrome
# true = tra cứu nền (không hiện cửa sổ Chrome/Edge trên máy chủ); false = mở cửa sổ khi debug
COSING_HEADLESS=true
# Sau bảng kết quả: mở trang chi tiết + (nếu có) substance liên quan — mô tả, SCCS, nồng độ tối đa… (chậm hơn)
COSING_ENRICH_DETAIL=true
