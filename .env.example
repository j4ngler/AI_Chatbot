# Sao chép thành .env và điền giá trị. Docker Compose đọc env_file nếu có file .env.

# LLM: hiện chỉ dùng Ollama. (OpenAI / Gemini — tạm gỡ khỏi code; bật lại sau nếu cần.)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
# Giảm drift sang tiếng Trung với Qwen: 0.05–0.15 (mặc định 0.15)
OLLAMA_TEMPERATURE=0.15
# Giới hạn token sinh → Ollama trả lời nhanh hơn (câu pháp luật ngắn thường đủ); tăng nếu cần đoạn dài
OLLAMA_NUM_PREDICT=512

# RAG (tùy chọn)
RAG_MODE=
HYBRID_ALPHA=0.5
# HYBRID_ALPHA=0 → chỉ TF-IDF trong pool, bỏ encode câu hỏi (nhanh hơn, kém mịn hơn với diễn đạt lạ)
RETRIEVE_K=20
TOP_K_DEFAULT=3
# Thu nhỏ gửi vào LLM (mặc định 1400 / 4500) để giảm latency; giảm dần nếu vẫn đủ chất lượng
CONTEXT_CHUNK_MAX_CHARS=1400
CONTEXT_MAX_TOTAL_CHARS=4500
# Số embedding câu hỏi cache (hybrid); 0 = tắt
QUERY_EMBED_CACHE_MAX=128
MIN_RETRIEVAL_SCORE=
DENSE_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
VECTOR_STORE_DIR=data/vector_db/file_based_demo

ROUTER_ENABLED=true
REFLECTION_ENABLED=
# Tăng tốc nhưng giữ độ chính xác: adaptive retrieval + nén context theo từ khóa + cache trả lời
FAST_ACCURATE_MODE=true
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_TTL_SECONDS=300
ANSWER_CACHE_MAX_ITEMS=300

# Demo web: CORS, danh sách origin cách nhau bởi dấu phẩy (mặc định *)
CORS_ALLOW_ORIGINS=*

# CoSIng (EU) — tab tra cứu hóa chất trên demo; cần Chrome/Edge + Selenium
COSING_ENABLED=false
COSING_CACHE_DIR=data/cache/cosing
COSING_BROWSER=chrome
# true = tra cứu nền (không hiện cửa sổ Chrome/Edge trên máy chủ); false = mở cửa sổ khi debug
COSING_HEADLESS=true
# Sau bảng kết quả: mở trang chi tiết + (nếu có) substance liên quan — mô tả, SCCS, nồng độ tối đa… (chậm hơn)
COSING_ENRICH_DETAIL=true
# Tra cứu CoSIng nhiều dòng (POST /api/cosing/lookup/batch); tối đa 200
COSING_BATCH_MAX_QUERIES=50
# Giới hạn kích thước file upload batch (byte), tối đa 5MB trong code
COSING_BATCH_UPLOAD_MAX_BYTES=262144

# Bảo mật demo: đặt API_KEY để bắt buộc header X-API-Key hoặc Authorization: Bearer (một số route /api/* vẫn mở cho web demo — xem _api_key_public_path trong api/main.py)
# API_KEY=
# Ghi log audit (POST/PUT/DELETE/PATCH vào /api/*) + auth_fail khi bật key
AUDIT_LOG_ENABLED=false
AUDIT_LOG_PATH=logs/audit.jsonl
# Giới hạn theo IP (phút)
RATE_LIMIT_UPLOAD_PER_MIN=30
RATE_LIMIT_BATCH_JOBS_PER_MIN=15

# Nguồn ngoài (mỗi bộ = EXTERNAL_SOURCE_<ID>_ENABLED / _LABEL / _URL_TEMPLATE, ID viết hoa + gạch dưới)
# Ví dụ (httpbin — chỉ để test, tắt mặc định):
# EXTERNAL_SOURCE_HTTPBIN_ENABLED=false
# EXTERNAL_SOURCE_HTTPBIN_LABEL=httpbin echo
# EXTERNAL_SOURCE_HTTPBIN_URL_TEMPLATE=https://httpbin.org/get?echo={query}

# Ingest PDF/ảnh → chờ duyệt → index (OCR cần cài Tesseract trên OS + pytesseract)
INGEST_PENDING_DIR=data/ingest_pending
INGEST_MAX_UPLOAD_BYTES=15728640
